# FoxDesk iOS release gate environment template.
#
# Usage:
#   npm run ios:release:init
#   edit .env.ios-release
#   npm run ios:release:env
#   npm run ios:submission:gate
#
# Never commit .env.ios-release. It may contain App Review credentials,
# smoke-test passwords, and a physical-device APNs token. The iOS gate scripts
# auto-load it when present.

# Human Apple gates. Set to 1 only after the operator has completed each step.
APP_STORE_CONNECT_APP_RECORD_READY=0
APPLE_DEVELOPER_BUNDLE_READY=0
APPLE_BUSINESS_VERIFIED=1
APP_STORE_PRIVACY_REVIEWED=0

# App Review demo account. Use a disposable or curated populated workspace.
FOXDESK_IOS_DEMO_EMAIL=
FOXDESK_IOS_DEMO_PASSWORD=
FOXDESK_IOS_DEMO_2FA_CODE=
FOXDESK_IOS_DEMO_WRITE=0

# Live mobile API smoke account. Prefer staging for write smoke. A disposable
# production workspace is allowed only with an explicit acknowledgement below.
FOXDESK_IOS_SMOKE_BASE_URL=https://app.foxdesk.net/api/mobile/v1
FOXDESK_IOS_SMOKE_EMAIL=
FOXDESK_IOS_SMOKE_PASSWORD=
FOXDESK_IOS_SMOKE_2FA_CODE=
FOXDESK_IOS_SMOKE_WRITE=0
FOXDESK_IOS_ALLOW_PRODUCTION_WRITE_SMOKE=0

# Physical iPhone APNs smoke. Copy from iOS app Account -> Push diagnostics.
APNS_TEST_DEVICE_TOKEN=
APNS_TEST_ENVIRONMENT=production
