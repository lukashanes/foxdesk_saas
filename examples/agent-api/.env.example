# Copy this file to examples/agent-api/.env and paste a real key from
# Profile -> API access. Never commit the real .env file.

FOXDESK_BASE_URL=https://app.foxdesk.net
FOXDESK_API_TOKEN=fdx_replace_with_token_from_profile

# Optional defaults used by the sample scripts.
FOXDESK_TICKET_TITLE=Agent API smoke ticket
FOXDESK_TICKET_DESCRIPTION=Created through the FoxDesk Agent API quickstart.
FOXDESK_TICKET_ID=
FOXDESK_TICKET_HASH=
FOXDESK_COMMENT=Quick note from the Agent API quickstart.
FOXDESK_DURATION_MINUTES=30
FOXDESK_TIME_SUMMARY=API quickstart work log
FOXDESK_ORGANIZATION_ID=
FOXDESK_TIME_RANGE=this_month
FOXDESK_REPORT_LIMIT=100

# Production/staging smoke defaults. Read-only checks run by default.
# Set FOXDESK_AGENT_PROD_REPORT=1 only when the token has reports:read.
# Set FOXDESK_AGENT_PROD_WRITE=1 only for an explicit test workspace where
# creating a smoke ticket, internal comment, and 1-minute time entry is safe.
FOXDESK_AGENT_PROD_REPORT=0
FOXDESK_AGENT_PROD_WRITE=0
FOXDESK_AGENT_PROD_VIEW=all
FOXDESK_AGENT_PROD_TIME_RANGE=this_month
FOXDESK_AGENT_PROD_REPORT_LIMIT=5
FOXDESK_AGENT_PROD_TICKET_TITLE=
FOXDESK_AGENT_PROD_TICKET_DESCRIPTION=
FOXDESK_AGENT_PROD_IDEMPOTENCY_KEY=
