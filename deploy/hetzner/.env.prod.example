FOXDESK_DOMAIN=app.foxdesk.net
APP_NAME=FoxDesk
APP_URL=https://app.foxdesk.net
APP_DEBUG=false
TRUST_PROXY=true

DB_HOST=db
DB_PORT=3306
DB_NAME=foxdesk_prod
DB_USER=foxdesk
DB_PASS=replace_with_strong_database_password
MARIADB_ROOT_PASSWORD=replace_with_strong_root_password
SECRET_KEY=replace_with_64_hex_secret

BILLING_ENABLED=true
STRIPE_SECRET_KEY=sk_live_replace
STRIPE_WEBHOOK_SECRET=whsec_replace
STRIPE_PRICE_CLOUD_BASE=price_replace
STRIPE_PRICE_STORAGE_OVERAGE=price_replace
STRIPE_STORAGE_METER_EVENT_NAME=foxdesk_storage_extra_gb
BILLING_CURRENCY=EUR
BILLING_CLOUD_BASE_PRICE_CENTS=1900
BILLING_STORAGE_OVERAGE_PRICE_CENTS=79
BILLING_INCLUDED_STORAGE_BYTES=1073741824

MAIL_PROVIDER=cloudflare
CLOUDFLARE_ACCOUNT_ID=replace_with_account_id
CLOUDFLARE_EMAIL_API_TOKEN=replace_with_email_sending_token
CLOUDFLARE_EMAIL_FROM=noreply@foxdesk.net
CLOUDFLARE_EMAIL_FROM_NAME=FoxDesk
CLOUDFLARE_EMAIL_REPLY_TO=support@foxdesk.net

IMAP_ENABLED=false
IMAP_HOST=
IMAP_PORT=993
IMAP_ENCRYPTION=ssl
IMAP_VALIDATE_CERT=true
IMAP_USERNAME=
IMAP_PASSWORD=
IMAP_FOLDER=INBOX
IMAP_PROCESSED_FOLDER=Processed
IMAP_FAILED_FOLDER=Failed
IMAP_MAX_EMAILS_PER_RUN=50
IMAP_MAX_ATTACHMENT_SIZE=10485760
IMAP_DENY_EXTENSIONS=php,phtml,php3,php4,php5,phar,exe,bat,cmd,js,vbs,ps1,sh
IMAP_STORAGE_BASE=storage/tickets
IMAP_MARK_SEEN_ON_SKIP=true
IMAP_ALLOW_UNKNOWN_SENDERS=false

UPLOAD_DIR=uploads/
MAX_UPLOAD_SIZE=10485760
